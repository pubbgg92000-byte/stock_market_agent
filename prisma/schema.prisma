generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model WatchlistItem {
  id        String   @id @default(cuid())
  ticker    String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AnalysisReport {
  id         String   @id @default(cuid())
  ticker     String
  question   String?
  summary    String
  confidence Int
  payload    String
  createdAt  DateTime @default(now())

  @@index([ticker, createdAt])
}

model AlertRule {
  id             String   @id @default(cuid())
  ticker         String
  channel        String   @default("telegram")
  priceMovePct   Float    @default(3)
  newsImpact     Boolean  @default(true)
  filingDetected Boolean  @default(true)
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([ticker, enabled])
}

model SourceEvent {
  id        String   @id @default(cuid())
  ticker    String
  type      String
  title     String
  url       String?
  provider  String
  occurredAt DateTime?
  createdAt DateTime @default(now())

  @@index([ticker, type, createdAt])
}

model ProviderCache {
  key       String   @id
  provider  String
  payload   String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([provider, expiresAt])
}
